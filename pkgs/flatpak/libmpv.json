{
    "name": "libmpv",
    "buildsystem": "meson",
    "config-opts": [
        "-Dlibmpv=true",
        "-Dcplayer=false",
        "-Dbuild-date=false",
        "-Dalsa=disabled",
        "-Dlua=disabled"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man"
    ],
    "sources": [
        {
            "type": "archive",
            "url": "https://github.com/mpv-player/mpv/archive/v0.41.0.tar.gz",
            "sha256": "ee21092a5ee427353392360929dc64645c54479aefdb5babc5cfbb5fad626209"
        }
    ],
    "modules": [
        {
            "name": "ffmpeg",
            "cleanup": [
                "/include",
                "/lib/pkgconfig",
                "/share/ffmpeg/examples"
            ],
            "config-opts": [
                "--enable-shared",
                "--disable-static",
                "--enable-gnutls",
                "--enable-gpl",
                "--disable-doc",
                "--disable-programs",
                "--disable-encoders",
                "--disable-muxers",
                "--enable-libdav1d"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ffmpeg.org/releases/ffmpeg-8.1.2.tar.xz",
                    "sha256": "464beb5e7bf0c311e68b45ae2f04e9cc2af88851abb4082231742a74d97b524c"
                }
            ]
        },
        {
            "name": "libass",
            "cleanup": [
                "/include",
                "/lib/*.la",
                "/lib/pkgconfig"
            ],
            "config-opts": [
                "--disable-static"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libass/libass/releases/download/0.17.5/libass-0.17.5.tar.xz",
                    "sha256": "2dca25c0e0c837ddf00b52011b3f82cac1e4ddd3ad018227806b0c2288864acc"
                }
            ]
        },
        {
            "name": "libplacebo",
            "buildsystem": "meson",
            "cleanup": [
                "/include",
                "/lib/pkgconfig"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/haasn/libplacebo.git",
                    "tag": "v7.360.1",
                    "commit": "cee9b076f2c63104ccfd497fa79c39a867293ec4"
                }
            ]
        }
    ]
}
